# ─────────────────────────────────────────────
# Swiss Trails — Environment Variables
# Copy to .env.local and fill in real values
# ─────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=swiss-trails.com
NEXT_PUBLIC_APP_SUBDOMAIN=app.swiss-trails.com

# Auth.js (NextAuth)
AUTH_SECRET=your_32_char_secret_here
AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Resend (magic link email)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=hello@swiss-trails.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database (Prisma / Supabase pooler)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRODUCT_ID=prod_your_product_id
STRIPE_PRICE_ID=price_your_price_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Maps (optional — for Google Maps swap)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key
