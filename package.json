{
  "name": "swiss-trails-monorepo",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo run dev",
    "dev:marketing": "turbo run dev --filter=swiss-trails-marketing",
    "dev:app": "turbo run dev --filter=swiss-trails-app",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "react-leaflet>react": "^19.1.0",
      "react-leaflet>react-dom": "^19.1.0",
      "@react-leaflet/core>react": "^19.1.0",
      "@react-leaflet/core>react-dom": "^19.1.0"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "sharp",
      "unrs-resolver",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
